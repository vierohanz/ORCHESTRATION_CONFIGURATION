server {
    listen       80;
    listen  [::]:80;
    server_name  localhost;

    # Melayani file statis UI (index.html)
    location / {
        root   /usr/share/nginx/html;
        index  index.html index.htm;
        try_files $uri $uri/ =404;
    }

    # Reverse proxy untuk API Calculator
    location /api/ {
        # Meneruskan request ke backend Calculator di ubuntu-1 (port 5000)
        # 192.168.56.11 adalah IP ubuntu-1 tempat calculator.py.j2 berjalan
        proxy_pass http://192.168.56.11:5000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    error_page   500 502 503 504  /50x.html;
    location = /50x.html {
        root   /usr/share/nginx/html;
    }
}
