# Gunakan variabel hazelcast_host dari group_vars/all.yml
from flask import Flask, request, jsonify
import hazelcast

app = Flask(__name__)

# Koneksi ke Hazelcast menggunakan variabel Ansible (tidak hardcoded)
client = hazelcast.HazelcastClient(
    cluster_members=[
        "{{ hazelcast_host }}:{{ hazelcast_port }}"
    ]
)

history_map = client.get_map("calculator-history").blocking()

@app.route('/calc', methods=['GET'])
def calculate():
    op = request.args.get('op')
    try:
        a = float(request.args.get('a', 0))
        b = float(request.args.get('b', 0))
    except ValueError:
        return jsonify({"error": "Invalid numbers"}), 400

    result = 0
    if op == 'add':
        result = a + b
    elif op == 'sub':
        result = a - b
    elif op == 'mul':
        result = a * b
    elif op == 'div':
        if b == 0:
            return jsonify({"error": "Division by zero"}), 400
        result = a / b
    else:
        return jsonify({"error": "Invalid operation. Use add, sub, mul, div"}), 400

    operation_str = f"{a} {op} {b} = {result}"
    current_size = history_map.size()
    history_map.put(current_size, operation_str)

    return jsonify({
        "operation": op,
        "a": a,
        "b": b,
        "result": result,
        "message": "Saved to Hazelcast cache!"
    })

@app.route('/history', methods=['GET'])
def history():
    size = history_map.size()
    hist = [history_map.get(i) for i in range(size)]
    return jsonify({"history": hist})

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
